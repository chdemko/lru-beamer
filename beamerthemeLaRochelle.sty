\def\BTLRU@version{v0.1.0}
\def\BTLRU@date{2026/04/25}
\ProvidesPackage{beamerthemeLaRochelle}[\BTLRU@date\space\BTLRU@version\space La Rochelle University Beamer Theme]

\DeclareOptionBeamer{pagenumber}[]{\setbeamertemplate{page number in head/foot}[totalframenumber]}

\mode<presentation>

\useinnertheme{rounded}
\useoutertheme{LaRochelle}
\usecolortheme{LaRochelle}
\usefonttheme{LaRochelle}

\setbeamertemplate{itemize items}[triangle]
\setbeamertemplate{bibliography items}[triangle]

\ProcessOptionsBeamer

\mode<all>

